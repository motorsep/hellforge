                <object class="wxChoice" name="BuildingGeneratorWindowMode">
                  <selection>1</selection>
                  <content>
                    <item>None</item>
                    <item>Automatic</item>
                    <item>Fixed Count</item>
                  </content>
                </object>
              </object>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND|wxLEFT|wxRIGHT|wxBOTTOM</flag>
            <border>12</border>
            <option>0</option>
            <object class="wxPanel" name="BuildingGeneratorWindowCountPanel">
              <style>wxTAB_TRAVERSAL</style>
              <object class="wxFlexGridSizer" name="">
                <vgap>6</vgap>
                <hgap>12</hgap>
                <growablerows></growablerows>
                <growablecols>1</growablecols>
                <rows>1</rows>
                <cols>2</cols>
                <object class="sizeritem">
                  <flag>wxALIGN_CENTER_VERTICAL</flag>
                  <border>0</border>
                  <option>0</option>
                  <object class="wxStaticText" name="">
                    <label>Per Floor:</label>
                    <wrap>0</wrap>
