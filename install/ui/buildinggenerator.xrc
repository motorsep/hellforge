              <object class="sizeritem">
                <flag>wxEXPAND</flag>
                <border>0</border>
                <option>0</option>
                <object class="wxChoice" name="BuildingGeneratorRoofType">
                  <selection>0</selection>
                  <content>
                    <item>Flat</item>
                    <item>Flat with Border</item>
                    <item>Slanted</item>
                    <item>A-Frame</item>
                  </content>
                </object>
              </object>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND|wxLEFT|wxRIGHT|wxBOTTOM</flag>
            <border>12</border>
            <option>0</option>
            <object class="wxPanel" name="BuildingGeneratorRoofHeightPanel">
              <style>wxTAB_TRAVERSAL</style>
              <object class="wxFlexGridSizer" name="">
                <vgap>6</vgap>
                <hgap>12</hgap>
                <growablerows></growablerows>
                <growablecols>1</growablecols>
                <rows>1</rows>
                <cols>2</cols>
                <object class="sizeritem">
                  <flag>wxALIGN_CENTER_VERTICAL</flag>
                  <border>0</border>
                  <option>0</option>
                  <object class="wxStaticText" name="">
                    <label>Roof Height:</label>
                    <wrap>0</wrap>
                  </object>
                </object>
                <object class="sizeritem">
                  <flag>wxEXPAND</flag>
                  <border>0</border>
                  <option>0</option>
                  <object class="wxTextCtrl" name="BuildingGeneratorRoofHeight">
                    <value>64</value>
                    <maxlength>0</maxlength>
                  </object>
                </object>
              </object>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND|wxLEFT|wxRIGHT|wxBOTTOM</flag>
            <border>12</border>
            <option>0</option>
            <object class="wxPanel" name="BuildingGeneratorRoofBorderPanel">
              <style>wxTAB_TRAVERSAL</style>
              <object class="wxFlexGridSizer" name="">
                <vgap>6</vgap>
                <hgap>12</hgap>
                <growablerows></growablerows>
                <growablecols>1</growablecols>
                <rows>1</rows>
                <cols>2</cols>
                <object class="sizeritem">
                  <flag>wxALIGN_CENTER_VERTICAL</flag>
                  <border>0</border>
                  <option>0</option>
                  <object class="wxStaticText" name="">
                    <label>Border Height:</label>
                    <wrap>0</wrap>
                  </object>
                </object>
                <object class="sizeritem">
                  <flag>wxEXPAND</flag>
                  <border>0</border>
                  <option>0</option>
                  <object class="wxTextCtrl" name="BuildingGeneratorRoofBorderHeight">
                    <value>16</value>
                    <maxlength>0</maxlength>
                  </object>
                </object>
              </object>
            </object>
          </object>
        </object>
      </object>
      <object class="sizeritem">
        <flag>wxLEFT|wxRIGHT|wxBOTTOM|wxEXPAND</flag>
        <border>12</border>
        <option>0</option>
        <object class="wxFlexGridSizer" name="">
          <vgap>6</vgap>
          <hgap>6</hgap>
          <growablerows></growablerows>
          <growablecols>1</growablecols>
          <rows>2</rows>
          <cols>3</cols>
          <object class="sizeritem">
            <flag>wxALIGN_CENTER_VERTICAL</flag>
            <border>0</border>
            <option>0</option>
            <object class="wxStaticText" name="">
              <label>Wall Material:</label>
              <wrap>0</wrap>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND</flag>
            <border>0</border>
            <option>0</option>
            <object class="wxTextCtrl" name="BuildingGeneratorWallMaterial">
              <value>_default</value>
              <maxlength>0</maxlength>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxLEFT</flag>
            <border>6</border>
            <option>0</option>
            <object class="wxButton" name="BuildingGeneratorBrowseWallMaterial">
              <size>30,-1</size>
              <label>...</label>
              <default>0</default>
              <auth_needed>0</auth_needed>
              <markup>0</markup>
              <bitmap/>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALIGN_CENTER_VERTICAL</flag>
            <border>0</border>
            <option>0</option>
            <object class="wxStaticText" name="">
              <label>Trim Material:</label>
              <wrap>0</wrap>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND</flag>
            <border>0</border>
            <option>0</option>
            <object class="wxTextCtrl" name="BuildingGeneratorTrimMaterial">
              <value>_default</value>
              <maxlength>0</maxlength>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxLEFT</flag>
            <border>6</border>
            <option>0</option>
            <object class="wxButton" name="BuildingGeneratorBrowseTrimMaterial">
